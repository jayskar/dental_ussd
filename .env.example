SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
REDIS_URL=redis://127.0.0.1:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
ANON_THROTTLE_RATE=60/minute

# Docker-specific (set automatically by docker-compose but can be overridden)
# DB_DIR=/app/data          # Directory for the SQLite database file
# WEB_PORT=8000             # Host port mapped to the gunicorn container port
# GUNICORN_WORKERS=3        # Number of gunicorn worker processes
# GUNICORN_TIMEOUT=120      # Gunicorn worker timeout in seconds

# USSD Simulator (jayskar/ussd-simulator@mydev)
# VUE_APP_AUTH_TOKEN is baked into the simulator JS bundle at build time.
# Generate a DRF token first (after `docker compose up web`):
#   docker compose exec web python manage.py drf_create_token <username>
# Then set it here and rebuild:  docker compose build simulator
# VUE_APP_AUTH_TOKEN=your-drf-auth-token-here
# SIMULATOR_PORT=8081       # Host port for the simulator UI
